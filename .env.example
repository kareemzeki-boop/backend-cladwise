# Copy this to .env and fill in your values
PORT=5000

# PostgreSQL — get from Railway/Supabase dashboard
DATABASE_URL=postgresql://user:password@host:5432/dbname

# JWT — any long random string
JWT_SECRET=change_me_to_a_long_random_string

# Stripe — from stripe.com dashboard
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PRICE_ID=price_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Resend — from resend.com dashboard
RESEND_API_KEY=re_...

# Anthropic — from console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Frontend URL (for Stripe redirect)
CLIENT_URL=http://localhost:3000
